# rd-log environment variables
# All variables are prefixed with RD_LOG_ to avoid collisions.

# REQUIRED in production — a strong random secret for JWT signing.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
RD_LOG_SECRET_KEY=change-me-in-production

# Database URL. Defaults to local SQLite.
# For PostgreSQL: postgresql://user:pass@host:5432/dbname
RD_LOG_DATABASE_URL=sqlite:///./rd_log.db

# Environment name. Set to "production" on Railway.
# The app refuses to start in non-development mode with the default secret key.
RD_LOG_ENVIRONMENT=development

# Comma-separated CORS origins. Adjust for your deployment domain.
RD_LOG_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT algorithm (default: HS256)
RD_LOG_ALGORITHM=HS256

# Access token expiration in minutes (default: 1440 = 24 hours)
RD_LOG_ACCESS_TOKEN_EXPIRE_MINUTES=1440
